# Copy this file to .env and fill in your key(s)
# Get a free key at: https://www.electricitymaps.com/free-tier-api
ELECTRICITYMAPS_API_KEY=your_key_here

# Optional: enables LLM-generated scheduling explanations (wascheduler/llm/reasoning.py).
# Without this key, the scheduler falls back to a plain f-string explanation - no error.
# Get a free key at: https://build.nvidia.com (NVIDIA NIM)
NVIDIA_NIM_API_KEY=your_key_here
